# ============================================================
#  GHOSTHAUL — API KEYS SETUP GUIDE
#  Copy this file to .env.local and fill in your keys
#  All services below have FREE tiers — no credit card needed
# ============================================================

# ─────────────────────────────────────────────────────────────
# 1. SUPABASE  (Database + Auth + Realtime)
#    → Sign up FREE at https://supabase.com
#    → Create a new project
#    → Go to: Project Settings → API
#    → Copy "Project URL" and "anon public" key
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ─────────────────────────────────────────────────────────────
# 2. OPENROUTESERVICE  (Routing + ETA + Distance Matrix)
#    → Sign up FREE at https://openrouteservice.org/dev/#/signup
#    → Go to Dashboard → Tokens → Create Token
#    → Free: 2,000 requests/day (enough for demo + hackathon)
# ─────────────────────────────────────────────────────────────
ORS_API_KEY=YOUR_OPENROUTESERVICE_API_KEY

# ─────────────────────────────────────────────────────────────
# 3. OPEN-METEO  (Weather API — NO API KEY NEEDED!)
#    → Completely free, no signup, unlimited calls
#    → Docs: https://open-meteo.com/en/docs
#    → Just leave this as-is
# ─────────────────────────────────────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ─────────────────────────────────────────────────────────────
# 4. FIREBASE  (Push Notifications to Driver App)
#    → Sign up FREE at https://console.firebase.google.com
#    → Create project → Project Settings → Cloud Messaging
#    → Copy "Server key" from Cloud Messaging tab
#    → Free: Unlimited push notifications
# ─────────────────────────────────────────────────────────────
FIREBASE_SERVER_KEY=YOUR_FIREBASE_SERVER_KEY
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
NEXT_PUBLIC_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
NEXT_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# ─────────────────────────────────────────────────────────────
# 5. OSRM  (Self-hosted Routing — NO KEY NEEDED!)
#    → Either self-host: https://github.com/Project-OSRM/osrm-backend
#    → OR use free public demo server (for hackathon only):
#       http://router.project-osrm.org
#    → For production: host on Railway free tier
# ─────────────────────────────────────────────────────────────
OSRM_BASE_URL=http://router.project-osrm.org

# ─────────────────────────────────────────────────────────────
# 6. ANTHROPIC API  (AI Chat Assistant — Claude-powered)
#    → Sign up FREE at https://console.anthropic.com
#    → Create API key → Copy it here
#    → Free: $5 credit on signup (~5,000 queries with claude-haiku)
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY

# ─────────────────────────────────────────────────────────────
# 7. NOMINATIM  (Geocoding — NO API KEY NEEDED!)
#    → Free OpenStreetMap geocoding, no signup
#    → Docs: https://nominatim.org/release-docs/latest/api/Overview/
#    → Rate limit: 1 req/sec (fine for demo)
# ─────────────────────────────────────────────────────────────
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ─────────────────────────────────────────────────────────────
# 7. APP CONFIG
# ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-32-char-string-here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
